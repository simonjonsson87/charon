# =============================================================================
# Charon — Environment Variables
# Copy this file to .env and fill in your values before starting the agent.
# Never commit .env to version control.
#
# Ready-to-use network presets:
#   cp .env.mainnet .env   — all chains on mainnet
#   cp .env.testnet .env   — Shasta + Arbitrum Sepolia + Base Sepolia + Akash sandbox
# =============================================================================

# -----------------------------------------------------------------------------
# WALLET — HD wallet seed shared across all chains
# The agent derives all TRON payment addresses and EVM addresses from this
# single BIP-39 seed phrase. Store it securely; losing it means losing access
# to all derived wallets.
# -----------------------------------------------------------------------------
WDK_SEED_PHRASE="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# -----------------------------------------------------------------------------
# TRON — TronGrid API access
# Sign up at https://www.trongrid.io/ to get an API key.
# The agent uses TronGrid for TRC-20 event polling, account queries, and
# broadcasting forwarding transactions.
# -----------------------------------------------------------------------------
TRON_API_KEY=your_trongrid_api_key_here
TRON_RPC_URL=https://api.trongrid.io
# Contract addresses — defaults to mainnet values; override for testnet.
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_SUNSWAP_ROUTER=TKzxdSv2FZKQrEqkKVgp5DcwEXBEKMg2Ax
TRON_WTRX_CONTRACT=TNUC9Qb1rRpS5CbWLmNMxXBjyFoydXjWFR

# -----------------------------------------------------------------------------
# BASE NETWORK — RPC endpoint for x402 payment verification and USDC tracking
# The x402 middleware settles payments as USDC on Base. Use a reliable RPC
# provider (e.g., Alchemy, Infura, or Coinbase's public endpoint).
# -----------------------------------------------------------------------------
BASE_RPC_URL=https://mainnet.base.org
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# -----------------------------------------------------------------------------
# ARBITRUM — RPC endpoint for Aave lending operations
# The agent deposits idle float into Aave on Arbitrum to earn yield.
#
# Mainnet (Arbitrum One):
#   ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
#   AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD
#   AAVE_ASSET_ADDRESS=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9   # USDT
#
# Testnet (Arbitrum Sepolia):
#   ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
#   AAVE_POOL_ADDRESS=0xBfC91D59fdAA134A4ED45f7B584cAf96D7792Eff
#   AAVE_ASSET_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d   # USDC (no USDT on Sepolia)
#   Get testnet USDC from app.aave.com/faucet on Arbitrum Sepolia network.
#
# Leave ARBITRUM_RPC_URL blank to disable Aave features (safe for TRON-only testing).
# -----------------------------------------------------------------------------
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
USDT_ARBITRUM_ADDRESS=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
UNISWAP_SWAP_ROUTER=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
WETH9_ARBITRUM_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD
AAVE_ASSET_ADDRESS=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9

# -----------------------------------------------------------------------------
# COINBASE DEVELOPER PLATFORM — x402 facilitation
# These credentials are used by the @coinbase/x402-fastify middleware to
# act as the payment facilitator. Create a CDP project at
# https://developer.coinbase.com and generate a key pair.
# CDP_API_KEY_PRIVATE_KEY should be the full PEM string or base64-encoded key.
# -----------------------------------------------------------------------------
CDP_API_KEY_NAME=your_cdp_key_name_here
CDP_API_KEY_PRIVATE_KEY=your_cdp_private_key_here

# -----------------------------------------------------------------------------
# CLAWROUTER — x402-native inference (github.com/BlockRunAI/ClawRouter)
#
# ClawRouter is an OpenAI-compatible inference router that charges per request
# in USDC on Base via x402 micropayments. The agent pays for its own inference
# from the USDC it earns via the /payment/create x402 API fee — no credit card.
#
# Get the current base URL from the ClawRouter GitHub repo.
# The agent's Base wallet (derived from WDK_SEED_PHRASE) is used for payment;
# no separate API key is needed — your wallet is your auth.
# -----------------------------------------------------------------------------
CLAW_ROUTER_URL=https://api.clawrouter.ai/v1
CLAW_ROUTER_MODEL=claude
CLAW_ROUTER_MODEL_OPUS=opus

# Safety ceiling: refuse any x402 payment requirement above this USD amount.
# Protects against misconfigured or malicious routers asking for too much.
MAX_PAYMENT_PER_CALL_USDC=0.50

# -----------------------------------------------------------------------------
# OPENCLAW — agent framework configuration
# Points to the agent/ directory at the root of this repo. The bridge reads
# AGENTS.md, MEMORY.md, SOUL.md from this path on every session.
# -----------------------------------------------------------------------------
OPENCLAW_AGENT_PATH=./agent

# -----------------------------------------------------------------------------
# DATABASE — SQLite storage path
# The agent stores payments, address pool state, energy history, experiments,
# and daily metrics here. The data/ directory is created automatically.
# -----------------------------------------------------------------------------
SQLITE_PATH=./data/agent.db

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# BUSINESS LOGIC
# Adjust these to tune the relay's financial behaviour.
# -----------------------------------------------------------------------------

# Minimum payment amount in USDT. Requests below this are rejected.
# Prevents micro-transactions that aren't worth the forwarding gas cost.
MIN_PAYMENT_USDT=1.00

# Initial relay fee as a percentage of the payment amount.
# The agent may adjust this at runtime based on market conditions; this is
# the value used at first startup before the agent has set its own.
RELAY_FEE_PERCENT=0.3

# Number of days of transaction volume to keep as liquid USDT float.
# The remaining balance is eligible for deployment to Aave.
# E.g., 2 means the agent keeps 2 days' worth of payment throughput liquid.
AAVE_MIN_FLOAT_DAYS=2

# -----------------------------------------------------------------------------
# SCHEDULING
# -----------------------------------------------------------------------------

# Cron expression for the daily board meeting. Default: midnight UTC.
# The board meeting is the primary agent reasoning session. See AGENTS.md.
BOARD_MEETING_CRON="0 0 * * *"

# How often the payment monitor polls TronGrid for incoming TRC-20 transfers.
# Lower values improve payment detection latency but increase API usage.
# TronGrid free tier rate limits suggest 3000ms as a safe floor.
TRON_POLL_INTERVAL_MS=3000

# -----------------------------------------------------------------------------
# WEBHOOK DELIVERY — outbound payment notifications to developers
# -----------------------------------------------------------------------------

# Number of retry attempts before marking a webhook delivery as failed.
WEBHOOK_RETRY_COUNT=5

# Milliseconds to wait between webhook retry attempts.
WEBHOOK_RETRY_INTERVAL_MS=10000
